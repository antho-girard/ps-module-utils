{
  "name": "anthogirard/ps-module-utils",
  "description": "Library to make the module configuration quick & easy to develop. Also provides some useful tools.",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Anthony Girard",
      "homepage": "https://github.com/antho-girard"
    }
  ],
  "autoload": {
    "psr-4": {
      "AG\\PSModuleUtils\\": "lib"
    },
    "classmap": []
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\AG\\PSModuleUtils\\": "tests/Unit/"
    }
  },
  "require": {
    "php": ">=8.1 <8.5",
    "ext-curl": "*",
    "ext-json": "*",
    "phpdocumentor/reflection-docblock": "^6.0",
    "prestashop/module-lib-service-container": "^2.0",
    "alcohol/iso4217": "^4.3",
    "moneyphp/money": "^4.8"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "prestashop/php-dev-tools": "^5.0",
    "ircmaxell/random-lib": "^1.2",
    "prestashop/decimal": "^1.5",
    "phpstan/phpstan": "^2.1"
  }
}
